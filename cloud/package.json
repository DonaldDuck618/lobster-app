{
  "name": "lobster-app-cloud",
  "version": "1.0.0",
  "description": "🦞 龙虾 Agent - 云侧 Gateway 服务",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "NODE_ENV=development nodemon src/index.js",
    "start:staging": "NODE_ENV=staging node src/index.js",
    "start:prod": "NODE_ENV=production node src/index.js",
    "build": "echo 'No build step needed for JS'",
    "build:prod": "echo 'Production build ready'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:reset": "node scripts/reset-db.js",
    "deploy": "node scripts/deploy.js",
    "logs": "tail -f logs/*.log",
    "clean": "rm -rf uploads/* logs/*"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "winston": "^3.11.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "ioredis": "^5.3.2",
    "ws": "^8.16.0",
    "node-cron": "^3.0.3",
    "axios": "^1.6.7",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "jest": "^29.7.0",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DonaldDuck618/lobster-app.git"
  },
  "keywords": [
    "lobster",
