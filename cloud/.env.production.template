# 龙虾 Gateway - 生产环境配置
# 阿里云部署使用，真实服务

# ========== 服务器配置 ==========
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ========== JWT 配置 ==========
JWT_SECRET=lobster-production-secret-key-change-this-in-production-2026
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ========== 数据库配置 ==========
# 生产环境使用 RDS MySQL (待配置)
# DATABASE_URL=mysql://user:password@host:3306/lobster_prod
DATABASE_URL=

# ========== Redis 配置 ==========
# 生产环境使用 Redis 缓存 (待配置)
# REDIS_URL=redis://host:6379
REDIS_URL=
REDIS_PREFIX=lobster:prod:

# ========== 大模型 API 配置 ==========
# 生产环境使用真实 API
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_MOCK=false

# 智谱 GLM
ZHIPU_API_KEY=sk-your-zhipu-api-key
ZHIPU_MODEL=glm-4
ZHIPU_MOCK=false

# Moonshot Kimi
MOONSHOT_API_KEY=sk-your-moonshot-api-key
MOONSHOT_MODEL=kimi-plus
MOONSHOT_MOCK=false

# ========== 搜索 API 配置 ==========
TAVILY_API_KEY=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

# ========== 阿里云配置 ==========
# 已开通 - AccessKey (请替换为你的真实 Key)
ALIYUN_ACCESS_KEY_ID=LTAI5tYourAccessKeyId
ALIYUN_ACCESS_KEY_SECRET=YourAccessKeySecret

# 短信服务 - 真实发送 (待配置模板 CODE)
ALIYUN_SMS_MOCK=false
ALIYUN_SMS_SIGN_NAME=龙虾 Agent
ALIYUN_SMS_REGISTER_TEMPLATE=SMS_280756062
ALIYUN_SMS_LOGIN_TEMPLATE=SMS_280756063

# OSS 对象存储 - 真实存储 (待配置 Bucket)
OSS_MOCK=false
OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
OSS_BUCKET=lobster-app
OSS_ACCESS_KEY_ID=LTAI5tYourAccessKeyId
OSS_ACCESS_KEY_SECRET=YourAccessKeySecret

# 内容安全 - 真实审核
CONTENT_SECURITY_ENABLED=true
CONTENT_SECURITY_MOCK=false

# ========== 微信小程序配置 ==========
WECHAT_APPID=wx63721a0ef442fb67
WECHAT_SECRET=your-wechat-secret
WECHAT_GRANT_TYPE=client_credential
WECHAT_MOCK=false

# ========== 日志配置 ==========
LOG_LEVEL=info
LOG_FILE=logs/prod.log
LOG_TO_CONSOLE=false

# ========== 限流配置 ==========
# 生产环境严格限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========== 文件上传配置 ==========
UPLOAD_MAX_SIZE=104857600
UPLOAD_PATH=./uploads/prod

# ========== 生产环境专用 ==========
DEBUG=false
HOT_RELOAD=false
AUTO_RESTART=false

# 安全配置
HTTPS_ENABLED=true
CORS_ORIGIN=https://lobster-app.com
TRUST_PROXY=true
