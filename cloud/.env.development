# 龙虾 Gateway - 开发环境配置
# 本地开发使用，零成本

# ========== 服务器配置 ==========
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ========== JWT 配置 ==========
JWT_SECRET=lobster-dev-secret-key-not-for-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ========== 数据库配置 ==========
# 开发环境使用 SQLite (本地文件，无需安装)
DATABASE_URL=sqlite:./dev.db

# ========== Redis 配置 ==========
# 开发环境使用内存缓存
REDIS_URL=
REDIS_PREFIX=lobster:dev:

# ========== 大模型 API 配置 ==========
# 开发环境使用模拟响应 (不消耗额度)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_MOCK=true

# 智谱 GLM (模拟)
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4
ZHIPU_MOCK=true

# Moonshot Kimi (模拟)
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-plus
MOONSHOT_MOCK=true

# ========== 搜索 API 配置 ==========
# 可以使用真实 API (有免费额度)
TAVILY_API_KEY=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

# ========== 阿里云配置 ==========
# 开发环境使用模拟模式
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# 短信服务 - 模拟模式 (控制台打印验证码)
ALIYUN_SMS_MOCK=true
ALIYUN_SMS_SIGN_NAME=龙虾 Agent
ALIYUN_SMS_REGISTER_TEMPLATE=SMS_MOCK_001
ALIYUN_SMS_LOGIN_TEMPLATE=SMS_MOCK_002

# OSS 对象存储 - 本地存储
OSS_MOCK=true
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# 内容安全 - 模拟模式
CONTENT_SECURITY_ENABLED=false
CONTENT_SECURITY_MOCK=true

# ========== 微信小程序配置 ==========
# 开发环境可以配置测试账号
WECHAT_APPID=wx63721a0ef442fb67
WECHAT_SECRET=
WECHAT_GRANT_TYPE=client_credential
WECHAT_MOCK=true

# ========== 日志配置 ==========
LOG_LEVEL=debug
LOG_FILE=logs/dev.log
LOG_TO_CONSOLE=true

# ========== 限流配置 ==========
# 开发环境放宽限制
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# ========== 文件上传配置 ==========
UPLOAD_MAX_SIZE=104857600
UPLOAD_PATH=./uploads/dev

# ========== 开发工具 ==========
DEBUG=true
HOT_RELOAD=true
AUTO_RESTART=true
