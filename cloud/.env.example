# 龙虾 Gateway 环境变量配置

# 服务器配置
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/lobster_app
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis 配置
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=lobster:

# 大模型 API 配置
# 通义千问
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_MODEL=qwen-plus

# 智谱 GLM
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_MODEL=glm-4

# Moonshot Kimi
MOONSHOT_API_KEY=your-moonshot-api-key
MOONSHOT_MODEL=kimi-plus

# 搜索 API 配置
TAVILY_API_KEY=your-tavily-api-key
BAIDU_API_KEY=your-baidu-api-key

# 文件存储配置
OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
OSS_BUCKET=lobster-app
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret

# 内容安全配置 (阿里云)
CONTENT_SECURITY_ENABLED=true
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret

# 邮件配置 (可选)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-email-password

# 微信小程序配置
WECHAT_APPID=wx63721a0ef442fb67
WECHAT_SECRET=your-wechat-secret
WECHAT_GRANT_TYPE=client_credential

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/app.log

# 限流配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 文件上传配置
UPLOAD_MAX_SIZE=104857600
UPLOAD_PATH=./uploads
